<?xml version="1.0"?>
<robot name="differential_drive_robot"
xmlns:xacro="http://www.ros.org/wiki/xacro">
<!--Geometry and constants-->
<xacro:property name= "pi" value="3.14159"/>

<!--Dimensions-->
<xacro:property name="a" value="0.1"/>
<xacro:property name="b" value="0.3"/>
<xacro:property name="c" value="0.6"/>

<!--Wheel radius and distance between wheels-->
<xacro:property name="r" value="0.15"/>
<xacro:property name="d" value="0.1"/>

<!--Distances-->
<xacro:property name="s1" value="${b/2+r}"/>
<xacro:property name="s2" value="${2*r}"/>
<xacro:property name="s3" value="${2*r}"/>
<xacro:property name="s4" value="${c/2+d/2}"/>

<!--··········································-->
<!--Mass and Inertia properties-->
<!--··········································-->
<!--Densities-->
<xacro:property name="body_density" value="2710"/>
<xacro:property name="wheel_density" value="2710"/>
<xacro:property name="caster_density" value="2710"/>

<!--Moments of inertia for the body, wheels, and caster links -->

<!--Body properties-->
<xacro:property name="m1" value="${body_density * a * b * c}"/>
<xacro:property name="ixx_body" value="${m1 * (b*b + c*c) / 12}"/>
<xacro:property name="iyy_body" value="${m1 * (a*a + c*c) / 12}"/>
<xacro:property name="izz_body" value="${m1 * (a*a + b*b) / 12}"/>

<!--Wheel properties-->
<xacro:property name="m2" value="${wheel_density * pi * r * r * d}"/>
<xacro:property name="iz_wheel" value="${m2 * (0.5 * r * r)}"/>
<xacro:property name="i_wheel" value="${(1/12)*m2*(3*r*r+d*d)}"/>

<!--Caster properties-->
<xacro:property name="m3" value="${caster_density * 4/3 * pi * r * r * r}"/>
<xacro:property name="i_caster" value="${(2/5)*m3*r*r}"/>

<!--Inertias for the body, wheels, and caster links -->

<xacro:macro name="inertia_body">
  <inertial>
    <origin rpy="0 0 0" xyz="0 0 ${s1}"/>
    <mass value="${m1}"/>
    <inertia ixx="${ixx_body}" ixy="0" ixz="0" iyy="${iyy_body}" iyz="0" izz="${izz_body}"/>
  </inertial>
</xacro:macro>

<xacro:macro name="inertia_wheel">
  <inertial>
    <origin rpy="1.570795 0 0" xyz="0 0 0"/>
    <mass value="${m2}"/>
    <inertia ixx="${i_wheel}" ixy="0" ixz="0" iyy="${i_wheel}" iyz="0" izz="${iz_wheel}"/>
  </inertial>
</xacro:macro>

<xacro:macro name="inertia_caster">
  <inertial>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <mass value="${m3}"/>
    <inertia ixx="${i_caster}" ixy="0" ixz="0" iyy="${i_caster}" iyz="0" izz="${i_caster}"/>
  </inertial>
</xacro:macro>

<!--Additional files-->
<xacro:include filename="$(find differential_drive)/model/robot.gazebo"/>

<!--Base footprint-->
  <link name="base_footprint"></link>
  <joint name="body_link_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="body_link"/>
  </joint>
 
<!--BODY LINK-->
  <link name="body_link">
    <visual>
        <geometry>
          <box size="${a} ${b} ${c}"/>
        </geometry>
        <origin rpy="0 0 0" xyz="0 0 ${s1}"/>
      </visual>

    <collision name="body_collision">
      <geometry>
        <box size="${a} ${b} ${c}"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 ${s1}"/>
    </collision>

    <xacro:inertia_body/>
  </link>
 

<!--WHEEL LINKS and JOINTS-->
<joint name="wheel1_joint" type="continuous">
    <parent link="body_link"/>
    <child link="wheel1_link"/>
    <origin xyz="${-s2} ${-s4} ${r}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="50000" velocity="10"/>
    <dynamics damping="1" friction="1"/>
  </joint>

  <link name="wheel1_link">
    <visual>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="${d}" radius="${r}"/>
      </geometry>
    </visual>

    <collision>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="${d}" radius="${r}"/>
      </geometry>
    </collision>
    <xacro:inertia_wheel/>
  </link>


<joint name="wheel2_joint" type="continuous">
    <parent link="body_link"/>
    <child link="wheel2_link"/>
    <origin xyz="${-s2} ${s4} ${r}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="50000" velocity="10"/>
    <dynamics damping="1" friction="1"/>
  </joint>

  <link name="wheel2_link">
    <visual>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="${d}" radius="${r}"/>
      </geometry>
    </visual>

    <collision>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="${d}" radius="${r}"/>
      </geometry>
    </collision>
    <xacro:inertia_wheel/>
  </link>

<!--CASTER LINK AND JOINTS-->
<joint name="caster_joint" type="fixed">
    <parent link="body_link"/>
    <child link="caster_link"/>
    <origin xyz="${s3} 0 ${r}" rpy="0 0 0"/>
</joint>



<link name="caster_link">
    <visual>
    <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <sphere radius="${r}"/>
      </geometry>
    </visual>

    <collision>
    <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <sphere radius="${r}"/>
      </geometry>
    </collision>
    <xacro:inertia_caster/>
  </link>
</robot>